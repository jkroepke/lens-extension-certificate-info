{
  "name": "lens-certificate-info",
  "version": "4.3.7",
  "author": {
    "name": "Jan-Otto Kröpke",
    "email": "mail@jkroepke.de",
    "url": "https://github.com/jkroepke"
  },
  "publisher": "jkroepke",
  "description": "Freelens extension that shows certificate metadata from Kubernetes secrets.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkroepke/lens-extension-certificate-info.git",
    "directory": "."
  },
  "main": "out/main/index.js",
  "renderer": "out/renderer/index.js",
  "files": [
    "out/**/*"
  ],
  "copyright": "© 2021-2026 Jan-Otto Kröpke",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "biome": "pnpm dlx @biomejs/biome@2.5.3",
    "biome:check": "pnpm biome check",
    "biome:fix": "pnpm biome check --fix",
    "biome:migrate": "pnpm biome migrate --write",
    "trunk": "pnpm dlx @trunkio/launcher@1.3.4",
    "trunk:check": "pnpm trunk check",
    "trunk:check:all": "pnpm trunk check --all",
    "trunk:fix": "pnpm trunk check --fix",
    "trunk:fix:all": "pnpm trunk check --fix --all",
    "lint": "pnpm lint:check",
    "lint:check": "pnpm biome:check",
    "lint:fix": "pnpm biome:fix",
    "knip": "pnpm dlx knip@6.25.0 --dependencies --no-gitignore",
    "knip:check": "pnpm \"/^knip:(development|production)\\$/\"",
    "knip:development": "pnpm knip",
    "knip:production": "pnpm knip --production --strict",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "type:check": "tsc --noEmit -p tsconfig.json --composite false",
    "prebuild": "pnpm type:check",
    "build": "electron-vite build",
    "build:production": "VITE_PRESERVE_MODULES=false electron-vite build",
    "build:force": "electron-vite build",
    "bump-version": "pnpm version --no-commit-hooks --no-git-tag-version",
    "pack:dev": "pnpm bump-version prerelease && pnpm build:force && pnpm build && pnpm clean:tgz && pnpm pack && pnpm dlx shx@0.4.0 ls \"$PWD/*.tgz\"",
    "clean": "pnpm clean:out",
    "clean:dts": "pnpm dlx shx@0.4.0 rm -f \"src/**/*.d.scss.ts\"",
    "clean:node_modules": "pnpm dlx shx@0.4.0 rm -rf node_modules",
    "clean:out": "pnpm dlx shx@0.4.0 rm -rf out",
    "clean:tgz": "pnpm dlx shx@0.4.0 rm -f \"*.tgz\"",
    "clean:all": "pnpm \"/^clean:(dts|node_modules|out|tgz)\\$/\"",
    "postupdate": "pnpm biome:migrate"
  },
  "engines": {
    "node": ">= 22.16.0",
    "freelens": "^1.6.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@freelensapp/extensions": "^1.6.1",
    "@testing-library/react": "^12.1.5",
    "@types/node": "~22.15.35",
    "@types/react": "^17.0.93",
    "@vitejs/plugin-react": "^6.0.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "typescript": "6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/jkroepke/lens-extension-certificate-info",
  "bugs": {
    "url": "https://github.com/jkroepke/lens-extension-certificate-info/issues"
  },
  "keywords": [
    "extension",
    "k8slens",
    "lens",
    "freelensapp",
    "openlens",
    "freelens"
  ],
  "packageManager": "pnpm@11.9.0"
}
